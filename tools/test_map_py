import os
import sys
import numpy as np
import cv2

sys.path.insert(0, "/root/JDet/python")

from jdet.data.yolo_obb import img2label_path
from jdet.ops.yolo_obb_ops import obb_map_eval


val_txt = "/root/JDet/DV-full/val.txt"
nc = 5

predictions = []
ground_truths = []

with open(val_txt, "r") as f:
    img_paths = [x.strip() for x in f.readlines() if x.strip()]

num_imgs = len(img_paths)
print("num val images:", num_imgs)

for idx, img_path in enumerate(img_paths):
    image_id = os.path.basename(img_path)
    label_path = img2label_path(img_path)

    if not os.path.exists(label_path):
        continue

    # 处理空标签文件，避免 np.loadtxt warning
    if os.path.getsize(label_path) == 0:
        labels = np.zeros((0, 9), dtype=np.float32)
    else:
        labels = np.loadtxt(label_path, dtype=np.float32).reshape(-1, 9)

    if len(labels) == 0:
        continue

    img = cv2.imread(img_path)
    if img is None:
        print("[WARN] image read failed:", img_path)
        continue

    h, w = img.shape[:2]

    # normalized OBB -> original pixel OBB
    labels_orig = labels.copy()
    labels_orig[:, 1::2] *= w
    labels_orig[:, 2::2] *= h

    # 构造错误 image_id：把当前图像的 prediction 放到另一张图上
    # +100 是为了确保不是自己；取模避免越界
    wrong_img_path = img_paths[(idx + 100) % num_imgs]
    wrong_image_id = os.path.basename(wrong_img_path)

    # 极端保险：如果刚好一样，就再偏移一张
    if wrong_image_id == image_id:
        wrong_img_path = img_paths[(idx + 101) % num_imgs]
        wrong_image_id = os.path.basename(wrong_img_path)

    for lb in labels_orig:
        cls = int(lb[0])

        # 原始 GT polygon，像素坐标
        poly_gt = lb[1:9].astype(np.float32).copy()

        # GT 保持在正确 image_id 下
        ground_truths.append({
            "image_id": image_id,
            "cls": cls,
            "poly": poly_gt.copy(),
        })

        # Prediction 坐标不变，但 image_id 故意换成错误图像
        # 如果 evaluator 正确，这些 prediction 不应该匹配到原图 GT
        predictions.append({
            "image_id": wrong_image_id,
            "cls": cls,
            "score": 1.0,
            "poly": poly_gt.copy(),
        })

print("num predictions:", len(predictions))
print("num ground truths:", len(ground_truths))

res = obb_map_eval(predictions, ground_truths, num_classes=nc)

print("mAP50:", res["map50"])
print("mAP50-95:", res["map"])
print("AP50 per class:", res["ap50"])
print("GT per class:", res["n_gt_per_cls"])